#!/bin/sh
# ============================================================================
# pre-commit hook (BOM reject + CRLF enforce for .bat / .cmd)
#
# Delegates the actual check to check-bat-encoding.ps1 because reliable
# binary-level encoding inspection in POSIX shell is fragile across Git Bash
# / MSYS / Cygwin (od / hexdump availability varies). PowerShell ships with
# every Windows since PS 5.1 and gives us [System.IO.File]::ReadAllBytes.
#
# Activation: run ./Install-Hooks.ps1 once (sets core.hooksPath = .githooks).
# See SPECIFICATION.md section 3.7.9.1 (encoding rationale) and section
# 3.7.9.7 (fence implementation) for context.
# ============================================================================

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/.githooks/check-bat-encoding.ps1"

if [ ! -f "$SCRIPT" ]; then
    echo "[FAIL] pre-commit: $SCRIPT not found." >&2
    echo "       Re-run ./Install-Hooks.ps1 or restore the file from git." >&2
    exit 1
fi

# Prefer cross-platform PowerShell 7+ (`pwsh`) when available, fall back to
# Windows PowerShell (`powershell.exe`) which always ships with Windows.
# Both accept `-NoProfile -ExecutionPolicy Bypass -File`. macOS / Linux
# contributors are not the primary audience (this project is a Windows-only
# Godot game), but the fallback prevents the hook from hard-blocking commits
# on environments where neither `powershell.exe` nor `pwsh` would otherwise
# be reachable -- without resorting to silent pass.
if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT" -Mode Staged
    exit $?
fi
if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT" -Mode Staged
    exit $?
fi
echo "[FAIL] pre-commit: neither pwsh nor powershell.exe found on PATH." >&2
echo "       Install PowerShell 7+ (pwsh) or use a Windows shell to run encoding checks." >&2
echo "       Bypass: git commit --no-verify  (NOT recommended for .bat / .cmd)" >&2
exit 1
