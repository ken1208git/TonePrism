.DS_Store
Thumbs.db

# 一時ファイル
*.tmp
*.log
commit_message.txt
issue_temp.md
issue_*.md
temp_*.txt
draft_*.md

# Godot
.godot/
.import/
*.import
.mono/
data_*/
# 注: export_presets.cfg は Release.ps1 が読み取って書き換えるため tracked。
# Godot のデフォルト .gitignore では除外されるがこのプロジェクトでは管理対象

# C# / .NET (Manager用)
bin/
obj/
*.user
*.suo
.vs/
*.csproj.user

# データベース
toneprism.db
prism.db
# 注: prism.db は #168 (Bundle v0.5.0 brand rename) で toneprism.db に rename したが、
# 旧版 dev 環境からの transition 期間中の local 残置 file 用に gitignore は維持。
*.db-journal
*.db-wal

# データベースバックアップ（Manager のバックアップ機能で生成される）
backups/
# 旧版 Manager 由来でプロジェクトルート直下に作られた退避ファイル
safety_before_restore_*.db

# ゲームファイル（容量が大きいため除外）
games/

# ランタイム生成ファイル: SPEC §6.5 + §3.8.7 の drop folder / heartbeat 等。
# Launcher session JSON / unified logs root JSON 等は runtime に生成され、commit 対象ではない。
responses/

# リリース成果物（自動生成、git 追跡しない）
release/

# Release.ps1 が自動ダウンロードするツールチェーン
tools/godot/
tools/nuget-*.exe
