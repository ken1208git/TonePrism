<Page
    x:Class="TonePrism.Manager.Shell.PreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- (#245 PR5 step4) 「設定」セクションの暫定プレースホルダ。設定の即時反映実装 (#362) で本物の
         設定ページに置き換わるまでの honest な「準備中」表示。旧 Phase 0 の WPF-UI 見た目デモ (飾りトグル /
         無反応の「ゲーム登録 (例)」ボタン) は撤去済 — 押せそうで押せない飾りで混乱の元だったため。 -->
    <ScrollViewer Padding="36,28,36,28">
        <StackPanel>
            <TextBlock Text="設定" FontSize="28" FontWeight="Bold" />
            <ui:Card Margin="0,18,0,0" Padding="24">
                <StackPanel>
                    <TextBlock Text="準備中" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.7"
                        Text="ログ／バックアップの保存先・保持期間・自動バックアップの切り替えなどの設定項目を、即時反映対応 (#362) に合わせてこの画面へ移行します。" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
