<Page
    x:Class="TonePrism.Manager.Shell.GameListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Background="#FF202020">

    <!-- (#245 ② ゲーム一覧 WPF 化) 旧 GameHostPage (WinForms GameSectionPanel) を置換。一覧は Win11 設定アプリの
         「インストール済みアプリ」風のカード型リスト (角丸カード + アイコン + 2 行テキスト + 右にバージョン/表示バッジ)。
         操作 (追加/編集/版up/削除) は抽出済 service + 既存 WinForms フォームを、可視シェル窓 HWND (ShellOwner) を
         owner にして開く。ロジックは service 側＝本ページは配線のみ。
         注意: ListBox の ItemTemplate (DataTemplate) 内 TextBlock には暗黙スタイルが届かず WPF 既定の黒文字に
         落ちるため、テンプレ内テキストは必ず明示 Foreground を付ける。 -->

    <!-- (#245) WPF-UI NavigationView は内蔵 ScrollViewer でページ全体をスクロール可にする (lepoco/wpfui#1041)。
         root の MaxHeight を祖先 ScrollViewer の ViewportHeight に縛って viewport に収め、ページ全体スクロールを止める。
         こうすると内側の ListBox が内部スクロールし、ヘッダ行は固定で流れない。 -->
    <Grid MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportHeight}"
          PreviewMouseDown="Root_PreviewMouseDown">
    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- ヘッダ + 追加 -->
            <RowDefinition Height="Auto" />   <!-- 検索 -->
            <RowDefinition Height="Auto" />   <!-- フィルター / 並べ替え -->
            <RowDefinition Height="Auto" />   <!-- 件数 -->
            <RowDefinition Height="*" />      <!-- 一覧 -->
        </Grid.RowDefinitions>

        <!-- ヘッダ: タイトルのみ -->
        <TextBlock Grid.Row="0" Text="ゲーム" FontSize="26" FontWeight="Bold" Foreground="#F4F4F4" Margin="0,0,0,16" />

        <!-- 検索（短め・左）+ ゲームを追加（右）を同じ行に -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" x:Name="SearchBox" PlaceholderText="ゲームを検索（名前・ID・製作者）"
                        TextChanged="Search_TextChanged" IconPlacement="Right" Width="380" HorizontalAlignment="Left">
                <ui:TextBox.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:TextBox.Icon>
            </ui:TextBox>
            <ui:Button Grid.Column="2" x:Name="AddButton" Content="ゲームを追加" Appearance="Primary"
                       Click="Add_Click" VerticalAlignment="Center" />
        </Grid>

        <!-- フィルター (フライアウト) / 並べ替え -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <!-- フィルターボタン → フライアウトパネルで全軸を AND 絞り込み -->
            <ui:Button x:Name="FilterButton" Click="FilterButton_Click" VerticalAlignment="Center" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Filter24" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="FilterButtonText" Text="フィルター" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
            <Popup x:Name="FilterPopup" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="4"
                   Opened="FilterPopup_Opened" Closed="FilterPopup_Closed">
                <Border Background="#FF2A2A2A" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16"
                        MouseWheel="FilterPopup_MouseWheel">
                    <StackPanel Width="480">
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="フィルター" FontWeight="SemiBold" Foreground="#ECECEC" FontSize="14" VerticalAlignment="Center" />
                            <ui:Button Content="クリア" Appearance="Transparent" HorizontalAlignment="Right"
                                       Click="FilterClear_Click" FontSize="12" Padding="8,2" Cursor="Hand" />
                        </Grid>

                        <!-- 単一選択の4軸を2列に -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="ランチャー表示状態" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
                                <ComboBox x:Name="VisCombo" SelectedIndex="0" SelectionChanged="FilterCombo_Changed" Margin="0,0,0,10">
                                    <ComboBoxItem Content="すべて" />
                                    <ComboBoxItem Content="表示中のみ" />
                                    <ComboBoxItem Content="非表示のみ" />
                                </ComboBox>
                                <TextBlock Text="難易度" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
                                <ComboBox x:Name="DiffCombo" SelectedIndex="0" SelectionChanged="FilterCombo_Changed" Margin="0,0,0,10">
                                    <ComboBoxItem Content="すべて" />
                                    <ComboBoxItem Content="易しい" />
                                    <ComboBoxItem Content="普通" />
                                    <ComboBoxItem Content="難しい" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="通信プレイ" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
                                <ComboBox x:Name="ConnCombo" SelectedIndex="0" SelectionChanged="FilterCombo_Changed" Margin="0,0,0,10">
                                    <ComboBoxItem Content="すべて" />
                                    <ComboBoxItem Content="なし（1台で遊ぶ）" />
                                    <ComboBoxItem Content="ローカル通信" />
                                    <ComboBoxItem Content="オンライン通信" />
                                </ComboBox>
                                <TextBlock Text="プレイ時間" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
                                <ComboBox x:Name="TimeCombo" SelectedIndex="0" SelectionChanged="FilterCombo_Changed" Margin="0,0,0,10">
                                    <ComboBoxItem Content="すべて" />
                                    <ComboBoxItem Content="短い（～5分）" />
                                    <ComboBoxItem Content="普通（5～15分）" />
                                    <ComboBoxItem Content="長い（15分～）" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- プレイ人数: チェックで明示的に有効化したときだけ、ゲームの対応範囲 [Min,Max] がこの [下限,上限] と
                             重なるものを表示。コンボは index 0=「すべて」で OFF を示せるが、レンジは [1,99] が「絞らない」か
                             「1〜99人」か曖昧なのでチェックで OFF を明示する。NumberBox はチェック時のみ有効。 -->
                        <CheckBox x:Name="PlayerFilterCheck" Content="プレイ人数で絞り込む" Foreground="#ECECEC" FontSize="11.5"
                                  Margin="0,0,0,6" Checked="FilterCheck_Changed" Unchecked="FilterCheck_Changed" />
                        <!-- チェック OFF 時: IsEnabled=false で入力を止め、さらに Opacity で行全体を一様に減光する
                             (ui:NumberBox は IsEnabled=false でも矢印/数字が減光されず背景しか暗くならないため、
                             コンテナ Opacity で見た目を揃える)。 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                                    IsEnabled="{Binding ElementName=PlayerFilterCheck, Path=IsChecked}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=PlayerFilterCheck, Path=IsChecked}" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:NumberBox x:Name="PlayerMinBox" Minimum="1" Maximum="99" Value="1" Width="150"
                                          Foreground="#ECECEC" SpinButtonPlacementMode="Inline" ClearButtonEnabled="False" />
                            <TextBlock Text="〜" Foreground="#C4C8CC" VerticalAlignment="Center" Margin="10,0,10,0" />
                            <ui:NumberBox x:Name="PlayerMaxBox" Minimum="1" Maximum="99" Value="1" Width="150"
                                          Foreground="#ECECEC" SpinButtonPlacementMode="Inline" ClearButtonEnabled="False" />
                            <TextBlock Text="人" Foreground="#9AA0A6" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="ジャンル（複数選択可・いずれかを含む）" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,6" />
                        <ScrollViewer x:Name="GenreScroll" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="GenreScroll_PreviewMouseWheel">
                            <WrapPanel x:Name="GenrePanel" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>

            <ui:SymbolIcon Symbol="ArrowSort24" FontSize="16" Foreground="#9AA0A6" VerticalAlignment="Center" Margin="0,0,7,0" />
            <TextBlock Text="並べ替え:" Foreground="#C4C8CC" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="SortCombo" Width="140" SelectedIndex="0" SelectionChanged="View_Changed" VerticalAlignment="Center">
                <ComboBoxItem Content="タイトル" />
                <ComboBoxItem Content="製作者" />
                <ComboBoxItem Content="リリース年" />
            </ComboBox>
        </StackPanel>

        <!-- 件数 (Win11 の「N 個のアプリが見つかりました」風) -->
        <TextBlock Grid.Row="3" x:Name="CountText" Foreground="#9AA0A6" FontSize="13" Margin="2,0,0,10" Text="" />

        <!-- カード型リスト -->
        <ListBox x:Name="GamesList" Grid.Row="4"
                 Background="Transparent" BorderThickness="0" Padding="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="False"
                 PreviewKeyDown="GamesList_PreviewKeyDown"
                 MouseDoubleClick="GamesList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Padding" Value="0" />
                    <!-- クリック/フォーカス時に WPF 既定が描く黒い点線フォーカス枠を消す (青ハイライト廃止で露出した「黒枠」)。 -->
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Card" Background="#FF2B2B2B" BorderBrush="#14FFFFFF"
                                        BorderThickness="1" CornerRadius="8" Padding="16,12" SnapsToDevicePixels="True">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- ホバーのみ淡く反応。選択の青ハイライトは廃止 (操作はカードの ⋯ メニュー /
                                         ダブルクリックで、選択は内部用途のみ＝どのカードが選択中かを見せる必要がなく
                                         青発光は視覚的に煩いだけ)。選択の仕組み自体は CardMenu_Click 等で利用継続。 -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Card" Property="Background" Value="#FF333333" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <!-- 非表示ゲームはカードごと薄くして「ランチャーに出ない」を一目で示す。 -->
                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- アバター: サムネあれば UniformToFill で丸く敷く (アス比保持・縦横いっぱいまで拡大しトリミング)。
                             無ければ後ろのゲームアイコンが見える。サムネは背景ロードで後から差し替わる。 -->
                        <Grid Grid.Column="0" Width="42" Height="42" Margin="0,0,14,0" VerticalAlignment="Center">
                            <Border CornerRadius="9" Background="#FF3A3A3A">
                                <ui:SymbolIcon Symbol="Games24" FontSize="22" Foreground="#B8B8B8"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="9">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- タイトル + サブタイトル -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontSize="14.5" FontWeight="SemiBold"
                                       Foreground="#F0F0F0" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Subtitle}" FontSize="11.5" Foreground="#9AA0A6"
                                       Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- 右: バージョン (非表示ゲームはカードごと薄くするのでバッジは廃止) -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="14,0,2,0">
                            <TextBlock Text="{Binding Version}" FontSize="13" Foreground="#D8D8D8" HorizontalAlignment="Right" />
                        </StackPanel>

                        <!-- 各カードの操作メニュー。mousedown でトグル開閉 (開いてる時の再クリックは外側クリック扱いの
                             クローズだけにして再オープンを断つ)。Placement=Bottom でマウス位置でなくボタン下に固定。 -->
                        <ui:Button Grid.Column="3" Content="⋯" Appearance="Transparent" FontSize="18"
                                   Padding="10,2" Margin="8,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                   Click="CardMenu_Click" ToolTip="操作">
                            <ui:Button.ContextMenu>
                                <ContextMenu Placement="Bottom" Opened="CardMenu_Opened" Closed="CardMenu_Closed">
                                    <MenuItem Header="編集" Click="Edit_Click" FontSize="13" />
                                    <MenuItem Header="バージョンアップ" Click="VersionUp_Click" FontSize="13" />
                                    <Separator />
                                    <MenuItem Header="削除" Click="Delete_Click" FontSize="13" />
                                </ContextMenu>
                            </ui:Button.ContextMenu>
                        </ui:Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
    </Grid>
</Page>
