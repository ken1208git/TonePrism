<UserControl x:Class="TonePrism.Manager.Shell.GameForm.VersionEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:gf="clr-namespace:TonePrism.Manager.Shell.GameForm">
    <!-- (#324 PR1) 版管理 (edit 専用)。DataContext は host から EditViewModel を継承。版ドロップダウンの SelectedItem を
         VM.SelectedVersion に TwoWay バインドすることで、切替時に VM setter が「前版へ commit → 新版を load」を行う。
         版番号 rename は SemverInput(VM.VersionName)、更新メモは VM.VersionUpdateNote。
         版即時削除は #324 follow-up (旧 btnDeleteVersion ~200行は #242 で service 抽出しておらず PR1 では見送り)。 -->
    <StackPanel>
        <TextBlock Text="ランチャーに表示する／ここで編集するバージョン" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                  DisplayMemberPath="Version" Width="220" HorizontalAlignment="Left" Margin="0,0,0,12" />

        <TextBlock Text="バージョン番号" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
        <gf:SemverInput VersionString="{Binding VersionName, Mode=TwoWay}" HorizontalAlignment="Left" Margin="0,0,0,12" />

        <TextBlock Text="更新内容メモ（任意）" Foreground="#9AA0A6" FontSize="11.5" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding VersionUpdateNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True" TextWrapping="Wrap" Height="60" Foreground="#ECECEC" />
    </StackPanel>
</UserControl>
